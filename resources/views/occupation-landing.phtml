<div class="wt-page-content">
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <a class="btn btn-primary w-100 text-start p-3" href="<?= e($listUrl) ?>">
                <span class="d-block h4 mb-1"><?= MoreI18N::xlate('Occupations') ?></span>
