<?php View::push('javascript') ?>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const loading = document.querySelector('.occupation-standardizer-loading');
    const table = document.querySelector('.occupation-standardizer-loading + table.datatables');

    if (loading === null || table === null) {
        return;
    }

    const hideLoading = function () {
        loading.classList.add('d-none');
    };

    if (window.jQuery !== undefined) {
        window.jQuery(table).on('init.dt', hideLoading);
    }

    if (!table.classList.contains('d-none')) {
        hideLoading();
    }

    setTimeout(function () {
        if (!table.classList.contains('d-none')) {
            hideLoading();
        }
    }, 250);
});
</script>
<?php View::endpush() ?>

