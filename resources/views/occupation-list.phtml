<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Individual;
use Fisharebest\Webtrees\Tree;
use Hartenthaler\Webtrees\Module\OccupationStandardizer\Internationalization\MoreI18N;
use Illuminate\Support\Collection;


/**
 * @var bool $canManageNormalization
 * @var Collection<int,array{occupation:string,individual:Individual,date:string,place:string,place_sort:string,employer:string,type:string,note:string,sources:list<string>,normalizations:list<array{label:string,title:string,status:string}>,normalizationEntries:list<array{entry_key:string,part_index:int,original_part_text:string,social_status:string,occupation_normalized:string,office:string,qualification:string,code:string,status:string,reviewed:bool,rule_numbers:string}>}> $rows
 * @var list<string> $statusOptions
 * @var string       $title
 * @var Tree         $tree
 */
?>

<h2 class="wt-page-title"><?= e($title) ?></h2>

<div class="wt-page-content">
    <p>
        <?= I18N::translate('This list shows the original occupation facts.') ?>
    </p>

    <?php if ($rows->isEmpty()) : ?>
        <p class="alert alert-info">
            <?= I18N::translate('No occupation facts were found in this family tree.') ?>
        </p>
    <?php else : ?>
        <table class="table table-bordered table-sm wt-table datatables d-none"
            <?= view('lists/datatables-attributes') ?>
        >
            <thead>
                <tr>
                    <th><?= MoreI18N::xlate('Occupation') ?></th>
                    <th><?= MoreI18N::xlate('Individual') ?></th>
                    <th><?= MoreI18N::xlate('Date') ?></th>
                    <th><?= MoreI18N::xlate('Place') ?></th>
                    <th><?= MoreI18N::xlate('Employer') ?></th>
                    <th><?= MoreI18N::xlate('Type') ?></th>
                    <th><?= MoreI18N::xlate('Note') ?></th>
                    <th><?= MoreI18N::xlate('Sources') ?></th>
                    <?php if ($canManageNormalization) : ?>
                        <th><?= I18N::translate('Normalization') ?></th>
                    <?php endif ?>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($rows as $row) : ?>
                    <tr>
                        <td data-sort="<?= e($row['occupation']) ?>">
                            <bdi><?= e($row['occupation']) ?></bdi>
                            <?php foreach ($row['normalizations'] as $normalization) : ?>
                                <?php if ($normalization['label'] !== '') : ?>
                                    <span class="badge bg-secondary ms-1" title="<?= e($normalization['title']) ?>">
                                        <?= e($normalization['label']) ?>
                                    </span>
                                <?php endif ?>
                            <?php endforeach ?>
                        </td>
                        <td data-sort="<?= e($row['individual']->sortName()) ?>">
                            <a href="<?= e($row['individual']->url()) ?>"><?= $row['individual']->fullName() ?></a>
                        </td>
                        <td data-sort="<?= e(strip_tags($row['date'])) ?>"><?= $row['date'] ?></td>
                        <td data-sort="<?= e($row['place_sort']) ?>"><?= $row['place'] ?></td>
                        <td><bdi><?= e($row['employer']) ?></bdi></td>
                        <td><bdi><?= e($row['type']) ?></bdi></td>
                        <td><bdi><?= e($row['note']) ?></bdi></td>
                        <td>
                            <?php if ($row['sources'] !== []) : ?>
                                <bdi><?= e(implode('; ', $row['sources'])) ?></bdi>
                            <?php endif ?>
                        </td>
                        <?php if ($canManageNormalization) : ?>
                            <td data-sort="<?= e(implode(' ', array_map(static fn (array $entry): string => $entry['occupation_normalized'] . ' ' . $entry['social_status'] . ' ' . $entry['office'] . ' ' . $entry['qualification'] . ' ' . $entry['code'], $row['normalizationEntries']))) ?>">
                                <?php foreach ($row['normalizationEntries'] as $entry) : ?>
                                    <form method="post" class="mb-2">
                                        <?= csrf_field() ?>
                                        <input type="hidden" name="task" value="saveNormalizationEntry">
                                        <input type="hidden" name="entryKey" value="<?= e($entry['entry_key']) ?>">

                                        <div class="small text-muted mb-1">
                                            <?= I18N::translate('Original part') ?>:
                                            <bdi><?= e($entry['original_part_text']) ?></bdi>
                                        </div>

                                        <div class="row g-1 align-items-end">
                                            <div class="col-12 col-xl-6">
                                                <label class="form-label small mb-0"><?= I18N::translate('Social status') ?></label>
                                                <input class="form-control form-control-sm" type="text" name="socialStatus" value="<?= e($entry['social_status']) ?>">
                                            </div>
                                            <div class="col-12 col-xl-6">
                                                <label class="form-label small mb-0"><?= I18N::translate('Normalized occupation') ?></label>
                                                <input class="form-control form-control-sm" type="text" name="occupationNormalized" value="<?= e($entry['occupation_normalized']) ?>">
                                            </div>
                                            <div class="col-12 col-xl-6">
                                                <label class="form-label small mb-0"><?= I18N::translate('Office') ?></label>
                                                <input class="form-control form-control-sm" type="text" name="office" value="<?= e($entry['office']) ?>">
                                            </div>
                                            <div class="col-12 col-xl-6">
                                                <label class="form-label small mb-0"><?= I18N::translate('Qualification') ?></label>
                                                <input class="form-control form-control-sm" type="text" name="qualification" value="<?= e($entry['qualification']) ?>">
                                            </div>
                                            <div class="col-12 col-xl-4">
                                                <label class="form-label small mb-0"><?= I18N::translate('Code') ?></label>
                                                <input class="form-control form-control-sm" type="text" name="code" value="<?= e($entry['code']) ?>">
                                            </div>
                                            <div class="col-12 col-xl-4">
                                                <label class="form-label small mb-0"><?= MoreI18N::xlate('Status') ?></label>
                                                <select class="form-select form-select-sm" name="status">
                                                    <?php foreach ($statusOptions as $status) : ?>
                                                        <option value="<?= e($status) ?>" <?= $entry['status'] === $status ? 'selected' : '' ?>>
                                                            <?= I18N::translate($status) ?>
                                                        </option>
                                                    <?php endforeach ?>
                                                </select>
                                            </div>
                                            <div class="col-12 col-xl-4">
                                                <div class="form-check mt-2">
                                                    <input class="form-check-input" type="checkbox" name="reviewed" value="1" id="reviewed-<?= e($entry['entry_key']) ?>" <?= $entry['reviewed'] ? 'checked' : '' ?>>
                                                    <label class="form-check-label" for="reviewed-<?= e($entry['entry_key']) ?>">
                                                        <?= I18N::translate('Reviewed') ?>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button class="btn btn-primary btn-sm" type="submit">
                                                    <?= MoreI18N::xlate('Save') ?>
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                <?php endforeach ?>
                            </td>
                        <?php endif ?>
                    </tr>
                <?php endforeach ?>
            </tbody>
        </table>
    <?php endif ?>
</div>

