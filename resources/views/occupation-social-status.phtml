                                <tr>
                                    <td data-sort="<?= e($row['individual']->sortName()) ?>"><a href="<?= e($row['individual']->url()) ?>"><?= $row['individual']->fullName() ?></a></td>
                                    <td class="text-end" data-sort="<?= e((string) $row['occupation_count']) ?>"><?= I18N::number($row['occupation_count']) ?></td>
                                    <td class="text-end" data-sort="<?= e((string) $row['score']) ?>"><?= I18N::number($row['score'], 1) ?></td>
                                </tr>
                            <?php endforeach ?>
                        </tbody>
                    </table>
                </div>
            <?php endif ?>
        </div>
