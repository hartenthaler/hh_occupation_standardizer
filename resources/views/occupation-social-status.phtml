use Hartenthaler\Webtrees\Module\OccupationStandardizer\Internationalization\MoreI18N;

/**
 * @var array{
 *     hisclass:array{total:int,rows:list<array{label:string,count:int,share:float,bar_percentage:float}>},
 *     hisclass_5:array{total:int,rows:list<array{label:string,count:int,share:float,bar_percentage:float}>},
 *     person_rows:list<array{individual:Individual,score:float,occupation_count:int}>,
 *     person_count:int,
 *     tree_score:float|null
 * } $analysis
 * @var callable(array):string $listUrl
 * @var string $title
 * @var Tree $tree
 */

$renderHistogram = static function (string $title, array $histogram): void {
    ?>
    <section class="card h-100">
        <div class="card-header"><?= e($title) ?></div>
        <div class="card-body">
            <p class="small text-muted">
                <?= I18N::plural(
                    '%s visible normalized occupation with a classification is included.',
                    '%s visible normalized occupations with a classification are included.',
                    $histogram['total'],
                    I18N::number($histogram['total'])
                ) ?>
            </p>

            <?php if ($histogram['total'] === 0) : ?>
                <p class="alert alert-info mb-0"><?= I18N::translate('No classified occupation entries are available.') ?></p>
            <?php else : ?>
                <div class="hh-social-status-histogram">
                    <?php foreach ($histogram['rows'] as $row) : ?>
                        <div class="hh-social-status-row">
                            <div><?= e($row['label']) ?></div>
                            <div class="hh-social-status-track" aria-hidden="true">
                                <div class="hh-social-status-bar" style="width: <?= e((string) $row['bar_percentage']) ?>%;"></div>
                            </div>
                            <div class="text-end">
                                <?= I18N::number($row['count']) ?>
                                <span class="text-muted">(<?= I18N::percentage($row['share'], 1) ?>)</span>
                            </div>
                        </div>
                    <?php endforeach ?>
                </div>
            <?php endif ?>
        </div>
    </section>
    <?php
};
?>

<style>
    .hh-social-status-histogram {
        display: grid;
