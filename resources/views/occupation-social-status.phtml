</style>

<h2 class="wt-page-title"><?= e($title) ?></h2>

<div class="wt-page-content">
    <p class="d-flex flex-wrap gap-2 align-items-center p-2 mb-3 rounded border" style="background: var(--bs-tertiary-bg, rgba(0, 0, 0, .03));">
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'list'])) ?>">
            <?= MoreI18N::xlate('Occupations') ?>
        </a>
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'hierarchy'])) ?>">
            <?= I18N::translate('Occupation hierarchy (OhdAB)') ?>
        </a>
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'hisco-hierarchy'])) ?>">
            <?= I18N::translate('Occupation hierarchy (HISCO)') ?>
        </a>
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'frequencies'])) ?>">
            <?= I18N::translate('Frequency analysis') ?>
        </a>
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'inheritance'])) ?>">
            <?= I18N::translate('Inheritance analysis') ?>
        </a>
    </p>

    <p>
        <?= I18N::translate('The histograms count each visible classified normalized occupation once, independently of how many individuals have this occupation.') ?>
    </p>

    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <?php $renderHistogram(I18N::translate('HISCLASS distribution (12 classes)'), $analysis['hisclass']) ?>
        </div>
        <div class="col-12 col-xl-6">
            <?php $renderHistogram(I18N::translate('HISCLASS distribution (5 classes)'), $analysis['hisclass_5']) ?>
        </div>
    </div>

    <section class="card mt-3">
        <div class="card-header"><?= I18N::translate('HISCAM U1 score per individual') ?></div>
        <div class="card-body">
            <p>
                <?= I18N::translate('The score for an individual is the arithmetic mean of all visible occupation entries with an available HISCAM U1 value. Higher values indicate higher social status.') ?>
            </p>
            <p class="small text-muted">
                <?= I18N::translate('Evaluated individuals') ?>:
                <?= I18N::number($analysis['person_count']) ?>.
                <?php if ($analysis['tree_score'] !== null) : ?>
                    <?= I18N::translate('Mean score for the family tree') ?>:
                    <?= I18N::number($analysis['tree_score'], 1) ?>.
                <?php endif ?>
            </p>

            <?php if ($analysis['person_rows'] === []) : ?>
                <p class="alert alert-info mb-0"><?= I18N::translate('No individuals with a visible HISCAM U1 occupation value are available.') ?></p>
            <?php else : ?>
                <div class="table-responsive">
                    <table class="table table-striped table-sm wt-table datatables mb-0"
                        <?= view('lists/datatables-attributes') ?>
