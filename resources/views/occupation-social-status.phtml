        grid-template-columns: minmax(8rem, 10rem) minmax(8rem, 1fr) minmax(7rem, auto);
        gap: 0.75rem;
        align-items: center;
    }

    .hh-social-status-track {
        height: 0.8rem;
        overflow: hidden;
        border-radius: 0.25rem;
        background: var(--bs-secondary-bg, #e9ecef);
    }

    .hh-social-status-bar {
        height: 100%;
        min-width: 0.2rem;
        background: #4f6f52;
    }

    @media (max-width: 575.98px) {
        .hh-social-status-row {
            grid-template-columns: 1fr auto;
