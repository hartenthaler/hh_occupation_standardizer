<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Hartenthaler\Webtrees\Module\OccupationStandardizer\Internationalization\MoreI18N;

$links ??= [];
$managed ??= false;
$collapsed ??= false;
$displayLinks = $links !== [] ? $links : ($managed ? [['language' => '', 'url' => '']] : []);

/**
 * @var list<array{language:string,url:string}> $links
 * @var bool $managed
 * @var bool $collapsed
 */
?>

<details class="border rounded p-2" data-wikipedia-editor <?= $collapsed ? '' : 'open' ?>>
    <summary class="fw-semibold">
        Wikipedia
        <?php if ($links !== []) : ?>
            <span class="badge bg-secondary ms-1"><?= I18N::number(count($links)) ?></span>
        <?php endif ?>
    </summary>

    <div class="form-check mt-2 mb-2">
        <label class="form-check-label">
            <input class="form-check-input" type="checkbox" name="wikipediaLinksManaged" value="1" data-wikipedia-managed <?= $managed ? 'checked' : '' ?>>
            <?= I18N::translate('Maintain Wikipedia links manually') ?>
        </label>
    </div>

    <p class="small text-muted mb-2">
        <?= I18N::translate('When manual maintenance is disabled, Wikipedia links are obtained automatically from Wikidata.') ?>
    </p>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th class="w-25"><?= I18N::translate('Language code') ?></th>
                    <th><?= MoreI18N::xlate('URL') ?></th>
                    <th class="text-end"><span class="visually-hidden"><?= MoreI18N::xlate('Actions') ?></span></th>
                </tr>
            </thead>
            <tbody data-wikipedia-rows>
                <?php if ($displayLinks === []) : ?>
                    <tr data-wikipedia-empty>
                        <td class="small text-muted" colspan="3">
                            <?= I18N::translate('No Wikipedia links are available yet.') ?>
                        </td>
                    </tr>
                <?php endif ?>
                <?php foreach ($displayLinks as $link) : ?>
                    <tr data-wikipedia-row>
                        <td>
                            <input class="form-control form-control-sm" type="text" name="wikipediaLanguage[]" value="<?= e($link['language']) ?>" maxlength="20" placeholder="de" aria-label="<?= e(I18N::translate('Language code')) ?>" <?= $managed ? '' : 'disabled' ?>>
                        </td>
                        <td>
                            <input class="form-control form-control-sm" type="url" name="wikipediaUrl[]" value="<?= e($link['url']) ?>" title="<?= e($link['url']) ?>" placeholder="https://de.wikipedia.org/wiki/Article_title" aria-label="<?= e(MoreI18N::xlate('URL')) ?>" <?= $managed ? '' : 'disabled' ?>>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-outline-danger btn-sm" type="button" data-wikipedia-remove title="<?= e(I18N::translate('Remove Wikipedia link')) ?>" <?= $managed ? '' : 'disabled' ?>>
                                <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                <span class="visually-hidden"><?= I18N::translate('Remove Wikipedia link') ?></span>
                            </button>
                        </td>
                    </tr>
                <?php endforeach ?>
            </tbody>
        </table>
    </div>

    <button class="btn btn-outline-secondary btn-sm mt-2" type="button" data-wikipedia-add <?= $managed ? '' : 'disabled' ?>>
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        <?= I18N::translate('Add Wikipedia link') ?>
    </button>

    <template data-wikipedia-template>
        <tr data-wikipedia-row>
            <td>
                <input class="form-control form-control-sm" type="text" name="wikipediaLanguage[]" maxlength="20" placeholder="de" aria-label="<?= e(I18N::translate('Language code')) ?>">
            </td>
            <td>
                <input class="form-control form-control-sm" type="url" name="wikipediaUrl[]" placeholder="https://de.wikipedia.org/wiki/Article_title" aria-label="<?= e(MoreI18N::xlate('URL')) ?>">
            </td>
            <td class="text-end">
                <button class="btn btn-outline-danger btn-sm" type="button" data-wikipedia-remove title="<?= e(I18N::translate('Remove Wikipedia link')) ?>">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i>
                    <span class="visually-hidden"><?= I18N::translate('Remove Wikipedia link') ?></span>
                </button>
            </td>
        </tr>
    </template>
</details>

<script>
if (!window.hhWikipediaEditorInitialized) {
    window.hhWikipediaEditorInitialized = true;

    document.addEventListener('change', (event) => {
        const toggle = event.target.closest('[data-wikipedia-managed]');

        if (toggle === null) {
            return;
        }

        const editor = toggle.closest('[data-wikipedia-editor]');
        const enabled = toggle.checked;
        const rows = editor.querySelector('[data-wikipedia-rows]');

        if (enabled && rows.querySelector('[data-wikipedia-row]') === null) {
            const template = editor.querySelector('[data-wikipedia-template]');
            rows.append(template.content.cloneNode(true));
        }

        editor.querySelectorAll('[data-wikipedia-row] input, [data-wikipedia-remove], [data-wikipedia-add]').forEach((control) => {
            control.disabled = !enabled;
        });

        const hasRows = rows.querySelector('[data-wikipedia-row]') !== null;
        editor.querySelector('[data-wikipedia-empty]')?.classList.toggle('d-none', enabled || hasRows);
    });

    document.addEventListener('click', (event) => {
        const addButton = event.target.closest('[data-wikipedia-add]');

        if (addButton !== null) {
            const editor = addButton.closest('[data-wikipedia-editor]');
            const template = editor.querySelector('[data-wikipedia-template]');
            editor.querySelector('[data-wikipedia-rows]').append(template.content.cloneNode(true));
            return;
        }

        const removeButton = event.target.closest('[data-wikipedia-remove]');

        if (removeButton !== null) {
            removeButton.closest('[data-wikipedia-row]').remove();
        }
    });
}
</script>
