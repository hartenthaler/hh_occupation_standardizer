<script>
document.querySelectorAll('.wt-table-menu td.move').forEach(function (cell) {
    cell.addEventListener('click', function (event) {
        event.preventDefault();

        const row = cell.closest('tr');
        const body = row.parentNode;

        if (cell.classList.contains('up') && row.previousElementSibling !== null) {
            body.insertBefore(row, row.previousElementSibling);
        }

        if (cell.classList.contains('down') && row.nextElementSibling !== null) {
            body.insertBefore(row.nextElementSibling, row);
        }
    });
});

const ohdabSpecialDatabaseInput = document.getElementById('ohdab-special-database');
const ohdabSpecialDatabaseName = document.getElementById('ohdab-special-database-name');

if (ohdabSpecialDatabaseInput !== null && ohdabSpecialDatabaseName !== null) {
    ohdabSpecialDatabaseInput.addEventListener('change', function () {
        ohdabSpecialDatabaseName.textContent = ohdabSpecialDatabaseInput.files.length > 0
            ? ohdabSpecialDatabaseInput.files[0].name
            : <?= json_encode(I18N::translate('No file selected')) ?>;
    });
}
</script>
<?php View::endpush() ?>

