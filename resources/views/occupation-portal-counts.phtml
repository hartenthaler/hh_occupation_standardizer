<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\View;

/**
 * @var array<string,int> $counts
 * @var string|null $chartId
 * @var list<array{place:string,location_xref:string,latitude:float|null,longitude:float|null,count:int}>|null $placeRows
 * @var bool|null $showChart
 * @var string $title
 */
$chartId ??= 'occupation-portal-counts';
$placeRows ??= [];
$showChart ??= false;
$chartCounts = array_slice($counts, 0, 12, true);
$maximumCount = $chartCounts !== [] ? max($chartCounts) : 0;
$mapRows = array_values(array_filter($placeRows, static fn (array $row): bool => $row['latitude'] !== null && $row['longitude'] !== null));
$mapData = json_encode(
    $mapRows,
    JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_THROW_ON_ERROR
);
?>

<section class="card h-100">
    <div class="card-header">
        <?= e($title) ?>
    </div>
    <div class="card-body">
        <?php if ($counts === []) : ?>
            <p class="mb-0 text-muted"><?= I18N::translate('No entries are available.') ?></p>
        <?php elseif ($showChart) : ?>
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="<?= e($chartId) ?>-list-tab" data-bs-toggle="tab" data-bs-target="#<?= e($chartId) ?>-list" type="button" role="tab" aria-controls="<?= e($chartId) ?>-list" aria-selected="false">
                        <?= I18N::translate('List') ?>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="<?= e($chartId) ?>-chart-tab" data-bs-toggle="tab" data-bs-target="#<?= e($chartId) ?>-chart" type="button" role="tab" aria-controls="<?= e($chartId) ?>-chart" aria-selected="true">
                        <?= I18N::translate('Histogram') ?>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="<?= e($chartId) ?>-map-tab" data-bs-toggle="tab" data-bs-target="#<?= e($chartId) ?>-map" type="button" role="tab" aria-controls="<?= e($chartId) ?>-map" aria-selected="false">
                        <?= I18N::translate('Map') ?>
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade" id="<?= e($chartId) ?>-list" role="tabpanel" aria-labelledby="<?= e($chartId) ?>-list-tab" tabindex="0">
                    <table class="table table-sm mb-0">
                        <?php if ($placeRows !== []) : ?>
                            <thead>
                                <tr>
                                    <th><?= I18N::translate('Place') ?></th>
                                    <th><?= I18N::translate('Latitude') ?></th>
                                    <th><?= I18N::translate('Longitude') ?></th>
                                    <th class="text-end"><?= I18N::translate('Count') ?></th>
                                </tr>
                            </thead>
                        <?php endif ?>
                        <tbody>
                            <?php if ($placeRows !== []) : ?>
                                <?php foreach ($placeRows as $row) : ?>
                                    <tr>
                                        <td><bdi><?= e($row['place']) ?></bdi></td>
                                        <td><bdi><?= $row['latitude'] === null ? '' : e((string) $row['latitude']) ?></bdi></td>
                                        <td><bdi><?= $row['longitude'] === null ? '' : e((string) $row['longitude']) ?></bdi></td>
                                        <td class="text-end"><?= I18N::number($row['count']) ?></td>
                                    </tr>
                                <?php endforeach ?>
                            <?php else : ?>
                                <?php foreach ($counts as $label => $count) : ?>
                                    <tr>
                                        <td><bdi><?= e($label) ?></bdi></td>
                                        <td class="text-end"><?= I18N::number($count) ?></td>
                                    </tr>
                                <?php endforeach ?>
                            <?php endif ?>
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade show active" id="<?= e($chartId) ?>-chart" role="tabpanel" aria-labelledby="<?= e($chartId) ?>-chart-tab" tabindex="0">
                    <p class="small text-muted">
                        <?= I18N::translate('The chart shows the most frequent places for this occupation.') ?>
                    </p>
                    <?php foreach ($chartCounts as $label => $count) : ?>
                        <?php $width = $maximumCount > 0 ? max(4, (int) round(100 * $count / $maximumCount)) : 0 ?>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between gap-2 small">
                                <span class="text-truncate"><bdi><?= e($label) ?></bdi></span>
                                <span><?= I18N::number($count) ?></span>
                            </div>
                            <div class="progress" style="height: .6rem;">
                                <div class="progress-bar" role="progressbar" style="width: <?= e((string) $width) ?>%;" aria-valuenow="<?= e((string) $count) ?>" aria-valuemin="0" aria-valuemax="<?= e((string) $maximumCount) ?>"></div>
                            </div>
                        </div>
                    <?php endforeach ?>
                </div>

                <div class="tab-pane fade" id="<?= e($chartId) ?>-map" role="tabpanel" aria-labelledby="<?= e($chartId) ?>-map-tab" tabindex="0">
                    <?php if ($mapRows === []) : ?>
                        <p class="mb-0 text-muted"><?= I18N::translate('No coordinates are available for these places.') ?></p>
                    <?php else : ?>
                        <p class="small text-muted">
                            <?= I18N::translate('The map uses coordinates from linked _LOC records.') ?>
                        </p>
                        <div
                            id="<?= e($chartId) ?>-leaflet"
                            role="region"
                            aria-label="<?= e(I18N::translate('Map')) ?>"
                            style="height: 360px; border: 1px solid var(--bs-border-color, #dee2e6);"
                        ></div>

                        <?php View::push('javascript') ?>
                        <script>
                        (() => {
                            const mapElement = document.getElementById(<?= json_encode($chartId . '-leaflet', JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>);
                            const mapTab = document.getElementById(<?= json_encode($chartId . '-map-tab', JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>);
                            const rows = <?= $mapData ?>;
                            const countLabel = <?= json_encode(I18N::translate('Count'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
                            const loadError = <?= json_encode(I18N::translate('The map could not be loaded.'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
                            let map = null;

                            function escapeHtml(value) {
                                const element = document.createElement('span');
                                element.textContent = value;

                                return element.innerHTML;
                            }

                            function markerIcon(count) {
                                const size = Math.min(34, Math.max(20, Math.sqrt(count) * 8));

                                return L.divIcon({
                                    className: '',
                                    html: `<div style="
                                        width:${size}px;height:${size}px;
                                        background:#0d6efd;border-radius:50%;
                                        border:2px solid #fff;
                                        box-shadow:0 1px 3px rgba(0,0,0,.45);
                                        display:flex;align-items:center;justify-content:center;
                                        color:#fff;font-size:${Math.round(size * .42)}px;font-weight:bold;">
                                        ${count}
                                    </div>`,
                                    iconSize: [size, size],
                                    iconAnchor: [size / 2, size / 2],
                                });
                            }

                            function initializeMap() {
                                if (map !== null) {
                                    map.invalidateSize();
                                    return;
                                }

                                if (mapElement === null || typeof L === 'undefined') {
                                    if (mapElement !== null) {
                                        mapElement.innerHTML = `<p class="p-3 text-muted">${escapeHtml(loadError)}</p>`;
                                    }
                                    return;
                                }

                                map = L.map(mapElement, { preferCanvas: true });
                                L.tileLayer('https://tile.openstreetmap.de/{z}/{x}/{y}.png', {
                                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · <a href="https://www.openstreetmap.de">OSM Deutschland</a>',
                                    maxZoom: 18,
                                }).addTo(map);

                                const markers = [];
                                const markerLayer = typeof L.markerClusterGroup === 'function'
                                    ? L.markerClusterGroup({
                                        maxClusterRadius: 50,
                                        showCoverageOnHover: false,
                                        chunkedLoading: true,
                                    })
                                    : L.layerGroup();

                                rows.forEach(row => {
                                    const marker = L.marker([row.latitude, row.longitude], {
                                        icon: markerIcon(row.count),
                                        title: row.place,
                                        alt: row.place,
                                    });
                                    marker.bindPopup(
                                        `<strong>${escapeHtml(row.place)}</strong><br>${escapeHtml(countLabel)}: ${row.count}`,
                                        { maxWidth: 260 }
                                    );
                                    markerLayer.addLayer(marker);
                                    markers.push(marker);
                                });

                                markerLayer.addTo(map);
                                map.fitBounds(L.featureGroup(markers).getBounds().pad(.1), { maxZoom: 13 });
                            }

                            mapTab?.addEventListener('shown.bs.tab', () => {
                                initializeMap();
                                window.setTimeout(() => map?.invalidateSize(), 0);
                            });

                            if (mapTab?.classList.contains('active')) {
                                initializeMap();
                            }
                        })();
                        </script>
                        <?php View::endpush() ?>
                    <?php endif ?>
                </div>
            </div>
        <?php else : ?>
            <table class="table table-sm mb-0">
                <tbody>
                    <?php foreach ($counts as $label => $count) : ?>
                        <tr>
                            <td><bdi><?= e($label) ?></bdi></td>
                            <td class="text-end"><?= I18N::number($count) ?></td>
                        </tr>
                    <?php endforeach ?>
                </tbody>
            </table>
        <?php endif ?>
    </div>
</section>
