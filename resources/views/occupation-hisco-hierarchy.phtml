                        <?php if ($currentNode !== null && $ancestor['level'] === $currentNode['level'] && $ancestor['code'] === $currentNode['code']) : ?>
                            <span aria-current="page" title="<?= e($ancestor['description']) ?>">
                                <bdi><?= e($ancestor['label']) ?></bdi>
                            </span>
                        <?php else : ?>
                            <a href="<?= e($listUrl(['view' => 'hisco-hierarchy', 'level' => $ancestor['level'], 'code' => $ancestor['code']])) ?>" title="<?= e($ancestor['description']) ?>">
                                <bdi><?= e($ancestor['label']) ?></bdi>
                            </a>
                        <?php endif ?>
                    </li>
                <?php endforeach ?>
            </ol>
        </nav>

        <?php if ($currentNode !== null) : ?>
            <div class="mb-3">
                <h3 class="h4 mb-1">
                    <bdi title="<?= e($currentNode['description']) ?>"><?= e($currentNode['label']) ?></bdi>
                </h3>
                <div class="text-muted">
                    <?= I18N::translate('HISCO hierarchy') ?>
                </div>
            </div>
        <?php elseif ($children === []) : ?>
            <p class="alert alert-info">
                <?= I18N::translate('No HISCO hierarchy entries were found.') ?>
            </p>
        <?php endif ?>

        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="occupation-hisco-hierarchy-children-tab" data-bs-toggle="tab" data-bs-target="#occupation-hisco-hierarchy-children" type="button" role="tab" aria-controls="occupation-hisco-hierarchy-children" aria-selected="true">
                    <?= I18N::translate('Subcategories') ?>
                    <span class="badge bg-secondary ms-1"><?= I18N::number(count($children)) ?></span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="occupation-hisco-hierarchy-persons-tab" data-bs-toggle="tab" data-bs-target="#occupation-hisco-hierarchy-persons" type="button" role="tab" aria-controls="occupation-hisco-hierarchy-persons" aria-selected="false">
                    <?= MoreI18N::xlate('Individuals') ?>
                    <span class="badge bg-secondary ms-1"><?= I18N::number($persons->count()) ?></span>
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="occupation-hisco-hierarchy-children" role="tabpanel" aria-labelledby="occupation-hisco-hierarchy-children-tab" tabindex="0">
                <?php if ($children === []) : ?>
                    <p class="alert alert-info">
                        <?= I18N::translate('There are no lower hierarchy levels for this entry.') ?>
                    </p>
                <?php else : ?>
                    <p class="text-muted">
                        <?= I18N::plural(
                            'The subcategories shown contain %s occupation entry for %s individual.',
                            'The subcategories shown contain %s occupation entries for %s individuals.',
                            $childEntryCount,
                            I18N::number($childEntryCount),
                            I18N::number($childIndividualCount)
                        ) ?>
                    </p>

                    <table class="table table-bordered table-sm wt-table">
