                            <tr>
                                <th><?= I18N::translate('Code') ?></th>
                                <th><?= I18N::translate('Hierarchy entry') ?></th>
                                <th class="text-end"><?= I18N::translate('Occupation entries') ?></th>
                                <th class="text-end"><?= MoreI18N::xlate('Individuals') ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($children as $child) : ?>
                                <tr>
                                    <td><bdi><?= e($child['code']) ?></bdi></td>
                                    <td>
                                        <a href="<?= e($listUrl(['view' => 'hisco-hierarchy', 'level' => $child['level'], 'code' => $child['code']])) ?>" title="<?= e($child['description']) ?>">
                                            <bdi><?= e($child['label']) ?></bdi>
                                        </a>
                                    </td>
                                    <td class="text-end" data-sort="<?= e((string) $child['entry_count']) ?>">
                                        <?= I18N::number($child['entry_count']) ?>
                                    </td>
                                    <td class="text-end" data-sort="<?= e((string) $child['individual_count']) ?>">
                                        <?= I18N::number($child['individual_count']) ?>
                                    </td>
                                </tr>
                            <?php endforeach ?>
                        </tbody>
                    </table>
                <?php endif ?>
            </div>

            <div class="tab-pane fade" id="occupation-hisco-hierarchy-persons" role="tabpanel" aria-labelledby="occupation-hisco-hierarchy-persons-tab" tabindex="0">
                <?php if ($currentNode === null) : ?>
                    <p class="alert alert-info">
                        <?= I18N::translate('Select a hierarchy entry to see the matching individuals.') ?>
                    </p>
                <?php elseif ($persons->isEmpty()) : ?>
                    <p class="alert alert-info">
                        <?= I18N::translate('No individuals were found for this hierarchy entry.') ?>
                    </p>
                <?php else : ?>
                    <table class="table table-bordered table-sm wt-table datatables"
                        <?= view('lists/datatables-attributes') ?>
                    >
                        <thead>
                            <tr>
                                <th><?= MoreI18N::xlate('Individual') ?></th>
                                <th><?= MoreI18N::xlate('Occupation') ?></th>
                                <th><?= I18N::translate('Original occupation') ?></th>
                                <th><?= MoreI18N::xlate('Date') ?></th>
                                <th><?= MoreI18N::xlate('Place') ?></th>
                                <th><?= MoreI18N::xlate('Sources') ?></th>
                            </tr>
                        </thead>
                        <tbody>
