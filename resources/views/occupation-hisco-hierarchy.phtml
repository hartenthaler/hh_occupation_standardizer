                                <tr>
                                    <td data-sort="<?= e($person['individual']->sortName()) ?>">
                                        <a href="<?= e($person['individual']->url()) ?>"><?= $person['individual']->fullName() ?></a>
                                    </td>
                                    <td data-sort="<?= e($person['label']) ?>">
                                        <span class="badge text-bg-light border" title="<?= e($person['label_title']) ?>">
                                            <bdi><?= e($person['label']) ?></bdi>
                                        </span>
                                    </td>
                                    <td><bdi><?= e($person['original_part_text']) ?></bdi></td>
                                    <td><bdi><?= e($person['date']) ?></bdi></td>
                                    <td><bdi><?= e($person['place']) ?></bdi></td>
                                    <td><bdi><?= e($person['source_names']) ?></bdi></td>
                                </tr>
                            <?php endforeach ?>
                        </tbody>
                    </table>
                <?php endif ?>
            </div>
        </div>
