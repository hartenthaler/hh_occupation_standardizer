<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Individual;
use Fisharebest\Webtrees\Tree;
use Hartenthaler\Webtrees\Module\OccupationStandardizer\Internationalization\MoreI18N;
use Illuminate\Support\Collection;

/**
 * @var list<array{level:string,code:string,label:string,description:string}> $ancestors
 * @var list<array{level:string,code:string,label:string,description:string,entry_count:int,individual_count:int}> $children
 * @var array{level:string,code:string,label:string,description:string}|null $currentNode
 * @var bool $hasSource
 * @var callable(array<string,bool|int|string|array<string>|null>):string $listUrl
 * @var Collection<int,array{individual:Individual,label:string,label_title:string,original_part_text:string,date:string,place:string,source_names:string}> $persons
 * @var string $title
 * @var Tree $tree
 */
$childEntryCount = array_sum(array_map(static fn (array $child): int => $child['entry_count'], $children));
$childIndividualCount = array_sum(array_map(static fn (array $child): int => $child['individual_count'], $children));
?>

<h2 class="wt-page-title"><?= e($title) ?></h2>

<div class="wt-page-content">
    <p class="d-flex flex-wrap gap-2 align-items-center p-2 mb-3 rounded border" style="background: var(--bs-tertiary-bg, rgba(0, 0, 0, .03));">
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl()) ?>">
            <?= MoreI18N::xlate('Occupations') ?>
        </a>
        <a class="btn btn-secondary btn-sm" href="<?= e($listUrl(['view' => 'hierarchy'])) ?>">
            <?= I18N::translate('Occupation hierarchy (OhdAB)') ?>
        </a>
    </p>

    <?php if (!$hasSource) : ?>
        <p class="alert alert-info">
            <?= I18N::translate('No HISCO catalog tables are available yet.') ?>
        </p>
    <?php else : ?>
        <nav aria-label="<?= e(I18N::translate('HISCO hierarchy')) ?>" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="<?= e($listUrl(['view' => 'hisco-hierarchy'])) ?>">HISCO</a>
                </li>
                <?php foreach ($ancestors as $ancestor) : ?>
